[gd_resource type="ShaderMaterial" format=3 uid="uid://pdii1wmfyjkq"]

[sub_resource type="Shader" id="Shader_o0rlf"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_burley, specular_schlick_ggx;

uniform float wave_speed : hint_range(0.0, 5.0) = 0.6;
uniform float wave_height : hint_range(0.0, 1.0) = 0.18;
uniform vec4 shallow_color : source_color = vec4(0.12, 0.52, 0.62, 0.78);
uniform vec4 deep_color : source_color = vec4(0.04, 0.18, 0.42, 0.92);

void vertex() {
	float t = TIME * wave_speed;
	VERTEX.y += sin(VERTEX.x * 1.8 + t) * wave_height;
	VERTEX.y += sin(VERTEX.z * 1.4 + t * 0.7) * wave_height * 0.6;
	VERTEX.y += sin((VERTEX.x + VERTEX.z) * 0.9 + t * 1.2) * wave_height * 0.4;
}

void fragment() {
	float fresnel = pow(clamp(1.0 - dot(NORMAL, VIEW), 0.0, 1.0), 2.5);
	vec3 water_col = mix(shallow_color.rgb, deep_color.rgb, fresnel * 0.6);
	water_col = mix(water_col, vec3(0.88, 0.94, 1.0), fresnel * 0.25);
	ALBEDO = water_col;
	ALPHA = mix(shallow_color.a, deep_color.a, fresnel * 0.5);
	ROUGHNESS = 0.04;
	METALLIC = 0.0;
	SPECULAR = 0.92;
}"

[resource]
render_priority = 0
shader = SubResource("Shader_o0rlf")
shader_parameter/wave_speed = 0.6
shader_parameter/wave_height = 0.18
shader_parameter/shallow_color = Color(0.12, 0.52, 0.62, 0.78)
shader_parameter/deep_color = Color(0.04, 0.18, 0.42, 0.92)
