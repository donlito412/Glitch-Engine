[gd_resource type="ShaderMaterial" format=3 uid="uid://kbc6a41nyalf"]

[sub_resource type="Shader" id="Shader_4m8aj"]
code = "shader_type spatial;

void fragment() {
	float slope = 1.0 - abs(NORMAL.y);
	float height = VERTEX.y;

	vec3 grass = vec3(0.22, 0.52, 0.14);
	vec3 dry_grass = vec3(0.48, 0.52, 0.22);
	vec3 dirt = vec3(0.40, 0.26, 0.13);
	vec3 rock = vec3(0.36, 0.33, 0.28);
	vec3 snow = vec3(0.92, 0.94, 0.96);

	vec3 col = mix(grass, dry_grass, smoothstep(0.0, 0.15, slope));
	col = mix(col, dirt, smoothstep(0.15, 0.45, slope));
	col = mix(col, rock, smoothstep(0.45, 0.75, slope));

	float uv_noise = fract(sin(dot(UV * 8.0, vec2(127.1, 311.7))) * 43758.5);
	col += (uv_noise - 0.5) * 0.03;

	ALBEDO = col;
	ROUGHNESS = mix(0.95, 0.7, smoothstep(0.3, 0.8, slope));
	METALLIC = 0.0;
}"

[resource]
render_priority = 0
shader = SubResource("Shader_4m8aj")
